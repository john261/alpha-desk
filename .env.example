# ─────────────────────────────────────────────────────────────
# ALPHA DESK — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control!
# ─────────────────────────────────────────────────────────────

# Supabase — get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Supabase Service Role Key — NEVER expose this to the client!
# Used only in server-side API routes.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# App URL (used for redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
